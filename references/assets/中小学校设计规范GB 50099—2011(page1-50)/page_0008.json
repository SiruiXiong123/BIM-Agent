        {
            "block_label": "text",
            "block_content": "4．2．1 中小学校用地应包括建筑用地、体育用地、绿化用地、道路及广场、停车场用地。有条件时宜预留发展用地。",
            "block_bbox": [
                147,
                370,
                1072,
                453
            ],
            "block_id": 2,
            "block_order": 3,
