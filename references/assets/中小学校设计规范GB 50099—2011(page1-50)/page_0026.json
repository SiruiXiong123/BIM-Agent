            ]
        },
        {
            "block_label": "text",
            "block_content": "5．8．4中小学校应有1间音乐教室能满足合唱课教学的要求，宜在紧接后墙处设置2排～3排阶梯式合唱台，每级高度宜为0．20m，宽度宜为0．60m。",
            "block_bbox": [
                147,
