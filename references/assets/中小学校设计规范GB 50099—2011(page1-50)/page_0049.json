                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "1 楼梯宽度为2股人流时，应至少在一侧设置扶手；",
            "block_bbox": [
                194,
                314,
                860,
                350
            ],
            "block_id": 2,
            "block_order": 3,
            "group_id": 2,
            "block_polygon_points": [
                [
                    194.0,
                    314.0
                ],
                [
                    860.0,
                    314.0
                ],
                [
                    860.0,
                    350.0
                ],
                [
                    194.0,
                    350.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "2 楼梯宽度达3股人流时，两侧均应设置扶手；",
            "block_bbox": [
                193,
                358,
                800,
                393
            ],
            "block_id": 3,
            "block_order": 4,
            "group_id": 3,
            "block_polygon_points": [
                [
                    193.0,
                    358.0
                ],
                [
                    800.0,
                    358.0
                ],
                [
                    800.0,
                    393.0
                ],
                [
                    193.0,
                    393.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "3 楼梯宽度达4股人流时，应加设中间扶手，中间扶手两侧的净宽均应满足本规范第8．7．2条的规定；",
            "block_bbox": [
                148,
                400,
                1072,
                480
            ],
            "block_id": 4,
            "block_order": 5,
            "group_id": 4,
            "block_polygon_points": [
                [
                    148.0,
                    400.0
