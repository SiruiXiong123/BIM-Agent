                ],
                [
                    1071.0,
                    366.0
                ],
                [
                    1071.0,
                    445.0
                ],
                [
                    148.0,
                    445.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "2 各教学用房的门均应向疏散方向开启，开启的门扇不得挤占走道的疏散通道；",
            "block_bbox": [
                148,
                452,
                1072,
                532
            ],
            "block_id": 4,
            "block_order": 5,
            "group_id": 4,
            "block_polygon_points": [
                [
                    148.0,
                    452.0
                ],
                [
                    1072.0,
                    452.0
                ],
                [
                    1072.0,
                    532.0
                ],
                [
                    148.0,
                    532.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "3 靠外廊及单内廊一侧教室内隔墙的窗开启后，不得挤占走道的疏散通道，不得影响安全疏散；",
            "block_bbox": [
                148,
                539,
                1074,
                619
            ],
            "block_id": 5,
            "block_order": 6,
            "group_id": 5,
            "block_polygon_points": [
