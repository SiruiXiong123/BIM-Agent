                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "5．12．3 容纳3个班及以上的合班教室应设计为阶梯教室。",
            "block_bbox": [
                147,
                535,
                910,
                571
            ],
            "block_id": 4,
            "block_order": 5,
            "group_id": 4,
            "block_polygon_points": [
                [
                    147.0,
