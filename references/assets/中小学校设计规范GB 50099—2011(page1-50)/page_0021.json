                    612.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "5．3．12 力学实验室需设置气垫导轨实验桌，在实验桌一端应设置气泵电源插座；另一端与相邻桌椅、墙壁或橱柜的间距不应小于0.90m。",
            "block_bbox": [
                147,
                651,
                1073,
                773
            ],
            "block_id": 4,
            "block_order": 5,
            "group_id": 4,
            "block_polygon_points": [
