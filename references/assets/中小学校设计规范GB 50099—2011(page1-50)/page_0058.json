        {
            "block_label": "text",
            "block_content": "10．1．1中小学校建筑的采暖通风与空气调节系统的设计应满足舒适度的要求，并符合节约能源的原则。",
            "block_bbox": [
                148,
                699,
                1072,
                780
            ],
            "block_id": 7,
            "block_order": 8,
            "group_id": 7,
            "block_polygon_points": [
