            ]
        },
        {
            "block_label": "text",
            "block_content": "6．2．20 寄宿制学校的食堂应包括学生餐厅、教工餐厅、配餐室及厨房。走读制学校应设置配餐室、发餐室和教工餐厅。",
            "block_bbox": [
                147,
                531,
                1073,
                611
            ],
            "block_id": 5,
            "block_order": 6,
            "group_id": 5,
            "block_polygon_points": [
