                [
                    783.0,
                    185.0
                ],
                [
                    147.0,
                    185.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "1 应根据在该走道上各教学用房疏散的总人数，按照本规范表8.2.3的规定计算走道的疏散宽度；",
            "block_bbox": [
                147,
                194,
                1059,
                272
            ],
            "block_id": 1,
            "block_order": 2,
            "group_id": 1,
            "block_polygon_points": [
                [
                    147.0,
                    194.0
                ],
                [
                    1059.0,
                    194.0
                ],
                [
                    1059.0,
                    272.0
                ],
                [
                    147.0,
                    272.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "2 走道疏散宽度内不得有壁柱、消火栓、教室开启的门窗扇等设施。",
            "block_bbox": [
                148,
                280,
                1072,
                359
            ],
            "block_id": 2,
            "block_order": 3,
            "group_id": 2,
            "block_polygon_points": [
