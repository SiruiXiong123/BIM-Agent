            ]
        },
        {
            "block_label": "text",
            "block_content": "5．7．3 美术教室应有良好的北向天然采光。当采用人工照明时，应避免眩光。",
            "block_bbox": [
                147,
                435,
                1075,
                516
            ],
            "block_id": 2,
            "block_order": 3,
            "group_id": 2,
            "block_polygon_points": [
