        {
            "block_label": "text",
            "block_content": "5.8.1 音乐教室应附设乐器存放室。",
            "block_bbox": [
                146,
                194,
                641,
                230
            ],
            "block_id": 1,
            "block_order": 2,
            "group_id": 1,
            "block_polygon_points": [
