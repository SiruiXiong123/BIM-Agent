                    780.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "10．1．2 中小学校的采暖与空调冷热源形式应根据所在地的气候特征、能源资源条件及其利用成本，经技术经济比较确定。",
            "block_bbox": [
                147,
                819,
                1072,
                902
            ],
            "block_id": 8,
            "block_order": 9,
            "group_id": 8,
            "block_polygon_points": [
