        {
            "block_label": "text",
            "block_content": "8．7．6 中小学校的楼梯扶手的设置应符合下列规定：",
            "block_bbox": [
                148,
                271,
                859,
                306
            ],
            "block_id": 1,
            "block_order": 2,
            "group_id": 1,
            "block_polygon_points": [
