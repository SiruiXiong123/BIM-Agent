                ],
                [
                    721.0,
                    360.0
                ],
                [
                    215.0,
                    360.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "2)在内走道墙上部设置排风口或在室内设附墙排风道此时排风口应贴近各层顶棚设置，并应可调节；",
            "block_bbox": [
                148,
                366,
                1070,
                445
            ],
            "block_id": 4,
            "block_order": 5,
            "group_id": 4,
            "block_polygon_points": [
                [
                    148.0,
                    366.0
                ],
                [
                    1070.0,
                    366.0
                ],
                [
                    1070.0,
                    445.0
                ],
                [
                    148.0,
                    445.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "3) 进风口面积不应小于房间面积的1/60；当房间采用散热器采暖时，进风口宜设在进风能被散热器直接加热的部位；",
            "block_bbox": [
                147,
                453,
                1072,
                532
            ],
            "block_id": 5,
            "block_order": 6,
            "group_id": 5,
            "block_polygon_points": [
                [
                    147.0,
                    453.0
                ],
                [
                    1072.0,
                    453.0
                ],
                [
                    1072.0,
                    532.0
                ],
                [
                    147.0,
                    532.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "4) 当排风口设于内走道时，其面积不应小于房间面积的1/30；当设置附墙垂直排风道时，其面积应通过计算确定；",
            "block_bbox": [
                147,
                539,
                1072,
                619
            ],
            "block_id": 6,
            "block_order": 7,
            "group_id": 6,
            "block_polygon_points": [
