        },
        {
            "block_label": "text",
            "block_content": "4．2．2 中小学校的规划设计应合理布局，合理确定容积率，合理利用地下空间，节约用地。",
            "block_bbox": [
                147,
                491,
                1072,
                573
            ],
            "block_id": 3,
            "block_order": 4,
            "group_id": 3,
            "block_polygon_points": [
