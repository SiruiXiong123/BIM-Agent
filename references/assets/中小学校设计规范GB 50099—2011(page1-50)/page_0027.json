                ]
            ]
        },
        {
            "block_label": "paragraph_title",
            "block_content": "Ⅰ风雨操场",
            "block_bbox": [
                539,
                492,
                686,
                526
            ],
            "block_id": 4,
            "block_order": 5,
            "group_id": 4,
            "block_polygon_points": [
                [
                    539.0,
                    492.0
                ],
                [
                    686.0,
                    492.0
                ],
                [
                    686.0,
                    526.0
                ],
                [
                    539.0,
                    526.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "5．10．2 风雨操场应附设体育器材室，也可与操场共用一个体育器材室，并宜附设更衣室、卫生间、浴室。教职工与学生的更衣室、卫生间、淋浴室应分设。",
            "block_bbox": [
                147,
                535,
                1074,
                658
            ],
            "block_id": 5,
            "block_order": 6,
            "group_id": 5,
            "block_polygon_points": [
                [
                    147.0,
                    535.0
                ],
                [
                    1074.0,
                    535.0
                ],
                [
                    1074.0,
                    658.0
                ],
                [
                    147.0,
                    658.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "5．10．3 当风雨操场无围护墙时，应避免眩光影响。有围护墙的风雨操场外窗无避免眩光的设施时，窗台距室内地面高度不宜低于2.10m。窗台高度以下的墙面宜为深色。",
            "block_bbox": [
                146,
                698,
                1072,
                824
            ],
            "block_id": 6,
            "block_order": 7,
            "group_id": 6,
            "block_polygon_points": [
                [
                    146.0,
                    698.0
                ],
                [
                    1072.0,
                    698.0
                ],
                [
                    1072.0,
                    824.0
                ],
                [
                    146.0,
                    824.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "5．10．4 根据运动占用空间的要求，应在风雨操场内预留各项目之间设置安全分隔的设施。",
            "block_bbox": [
                147,
                863,
                1073,
                944
            ],
            "block_id": 7,
            "block_order": 8,
            "group_id": 7,
            "block_polygon_points": [
                [
                    147.0,
                    863.0
                ],
                [
                    1073.0,
                    863.0
                ],
                [
                    1073.0,
                    944.0
                ],
                [
                    147.0,
                    944.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "5．10．5 风雨操场内，运动场地的灯具等应设护罩。悬吊物应有可靠的固定措施。有围护墙时，在窗的室内一侧应设护网。",
            "block_bbox": [
                147,
                984,
                1073,
                1065
            ],
            "block_id": 8,
            "block_order": 9,
            "group_id": 8,
            "block_polygon_points": [
                [
                    147.0,
                    984.0
                ],
                [
                    1073.0,
                    984.0
                ],
                [
                    1073.0,
                    1065.0
                ],
                [
                    147.0,
                    1065.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "5．10．6 风雨操场的楼、地面构造应根据主要运动项目的要求确定，不宜采用刚性地面。固定运动器械的预埋件应暗设。",
            "block_bbox": [
                146,
                1104,
                1057,
                1186
            ],
            "block_id": 9,
            "block_order": 10,
            "group_id": 9,
