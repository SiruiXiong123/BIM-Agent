                [
                    147.0,
                    418.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "5．12．2 各类中学宜配置能容纳一个年级或半个年级的合班教室。",
            "block_bbox": [
                147,
                458,
                1013,
                494
            ],
            "block_id": 3,
            "block_order": 4,
            "group_id": 3,
            "block_polygon_points": [
                [
                    147.0,
                    458.0
