            "block_label": "text",
            "block_content": "8.6.1 教学用建筑的走道宽度应符合下列规定：",
            "block_bbox": [
                147,
                150,
                783,
                185
            ],
            "block_id": 0,
            "block_order": 1,
            "group_id": 0,
            "block_polygon_points": [
                [
