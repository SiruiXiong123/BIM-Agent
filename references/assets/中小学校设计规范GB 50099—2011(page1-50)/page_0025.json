        {
            "block_label": "text",
            "block_content": "5．7．2 中学美术教室空间宜满足一个班的学生用画架写生的要求。学生写生时的座椅为画凳时，所占面积宜为2．15m²/生；用画架时所占面积宜为2．50m²/生。",
            "block_bbox": [
                146,
                271,
                1074,
                396
            ],
            "block_id": 1,
            "block_order": 2,
            "group_id": 1,
            "block_polygon_points": [
