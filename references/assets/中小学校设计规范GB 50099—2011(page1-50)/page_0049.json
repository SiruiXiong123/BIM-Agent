                [
                    148.0,
                    480.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "4 中小学校室内楼梯扶手高度不应低于0.90m，室外楼梯扶手高度不应低于1.10m；水平扶手高度不应低于1.10m；",
            "block_bbox": [
                149,
                487,
                1072,
                567
            ],
            "block_id": 5,
            "block_order": 6,
            "group_id": 5,
            "block_polygon_points": [
                [
                    148.49444580078125,
