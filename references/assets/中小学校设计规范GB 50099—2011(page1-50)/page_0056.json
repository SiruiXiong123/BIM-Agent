        },
        {
            "block_label": "text",
            "block_content": "1 应采取有效的通风措施，保证教学、行政办公用房及服务用房的室内空气中 $ CO_{2} $的浓度不超过0.15%；",
            "block_bbox": [
                149,
                576,
                1071,
                656
            ],
            "block_id": 3,
            "block_order": 2,
            "group_id": 3,
            "block_polygon_points": [
                [
