                [
                    890.0,
                    462.0
                ],
                [
                    147.0,
                    462.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "1 男生应至少为每40人设1个大便器或1．20m长大便槽；每20人设1个小便斗或0．60m长小便槽；女生应至少为每13人设1个大便器或1．20m长大便槽；",
            "block_bbox": [
                148,
                470,
                1073,
                592
            ],
            "block_id": 3,
            "block_order": 4,
            "group_id": 3,
            "block_polygon_points": [
