                ],
                [
                    910.0,
                    571.0
                ],
                [
                    147.0,
                    571.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "5．12．4 阶梯教室梯级高度依据视线升高值确定。阶梯教室的设计视点应定位于黑板底边缘的中点处。前后排座位错位布置时，视线的隔排升高值宜为0.12m。",
            "block_bbox": [
                147,
                613,
                1074,
                738
            ],
            "block_id": 5,
            "block_order": 6,
            "group_id": 5,
            "block_polygon_points": [
