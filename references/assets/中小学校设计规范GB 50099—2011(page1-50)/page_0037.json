        {
            "block_label": "text",
            "block_content": "6．2．18 食堂与室外公厕、垃圾站等污染源间的距离应大于25.00m。",
            "block_bbox": [
                147,
                357,
                1072,
                435
            ],
            "block_id": 3,
            "block_order": 4,
            "group_id": 3,
