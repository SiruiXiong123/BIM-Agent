                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "5．8．3 音乐教室讲台上应布置教师用琴的位置。",
            "block_bbox": [
                146,
                391,
                789,
                428
            ],
            "block_id": 3,
            "block_order": 4,
            "group_id": 3,
            "block_polygon_points": [
