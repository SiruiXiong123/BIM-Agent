        },
        {
            "block_label": "text",
            "block_content": "6．2．19 食堂不应与教学用房合并设置，宜设在校园的下风向。厨房的噪声及排放的油烟、气味不得影响教学环境。",
            "block_bbox": [
                148,
                444,
                1072,
                523
            ],
            "block_id": 4,
            "block_order": 5,
            "group_id": 4,
            "block_polygon_points": [
