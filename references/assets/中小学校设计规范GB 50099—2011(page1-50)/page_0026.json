        },
        {
            "block_label": "text",
            "block_content": "5．8．2 各类小学的音乐教室中，应有1间能容纳1个班的唱游课，每生边唱边舞所占面积不应小于2．40m^{2}。",
            "block_bbox": [
                147,
                270,
                1074,
                352
            ],
            "block_id": 2,
            "block_order": 3,
            "group_id": 2,
            "block_polygon_points": [
