        {
            "block_label": "text",
            "block_content": "5．3．11 当学校配置2个及以上物理实验室时，其中1个应为力学实验室。光学、热学、声学、电学等实验可共用同一实验室，并应配置各实验所需的设备和设施。",
            "block_bbox": [
                147,
                487,
                1074,
                612
            ],
            "block_id": 3,
            "block_order": 4,
            "group_id": 3,
            "block_polygon_points": [
