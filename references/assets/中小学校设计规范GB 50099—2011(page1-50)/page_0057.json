        },
        {
            "block_label": "text",
            "block_content": "1) 宜在外围护结构的下部设置进风口；",
            "block_bbox": [
                215,
                323,
                721,
                360
            ],
            "block_id": 3,
            "block_order": 4,
            "group_id": 3,
            "block_polygon_points": [
                [
                    215.0,
                    323.0
                ],
