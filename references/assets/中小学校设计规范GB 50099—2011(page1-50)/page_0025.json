        },
        {
            "block_label": "text",
            "block_content": "5．7．4 美术教室应设置书写白板，宜设存放石膏像等教具的储藏柜。在地质灾害多发地区附近的学校，教具储藏柜应与墙体或楼板有可靠的固定措施。",
            "block_bbox": [
                147,
                556,
                1076,
                680
            ],
            "block_id": 3,
            "block_order": 4,
            "group_id": 3,
