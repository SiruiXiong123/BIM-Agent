        {
            "block_label": "text",
            "block_content": "4．3．1 中小学校的总平面设计应包括总平面布置、竖向设计及管网综合设计。总平面布置应包括建筑布置、体育场地布置、绿地布置、道路及广场、停车场布置等。",
            "block_bbox": [
                146,
                674,
                1072,
                798
            ],
            "block_id": 6,
            "block_order": 7,
            "group_id": 6,
