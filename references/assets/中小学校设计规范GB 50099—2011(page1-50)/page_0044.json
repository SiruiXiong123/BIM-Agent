            ]
        },
        {
            "block_label": "text",
            "block_content": "1 疏散通道上的门不得使用弹簧门、旋转门、推拉门、大玻璃门等不利于疏散通畅、安全的门；",
            "block_bbox": [
                148,
                366,
                1071,
                445
            ],
            "block_id": 3,
            "block_order": 4,
            "group_id": 3,
            "block_polygon_points": [
