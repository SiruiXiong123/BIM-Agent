        {
            "block_label": "text",
            "block_content": "3 严寒与寒冷地区于冬季采用自然通风方式时，应符合下列规定：",
            "block_bbox": [
                200,
                279,
                1064,
                315
            ],
            "block_id": 2,
            "block_order": 3,
            "group_id": 2,
