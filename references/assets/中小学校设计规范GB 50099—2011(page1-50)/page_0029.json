        {
            "block_label": "text",
            "block_content": "5．12．1 各类小学宜配置能容纳2个班的合班教室。当合班教室兼用于唱游课时，室内不应设置固定课桌椅，并应附设课桌椅存放空间。兼作唱游课教室的合班教室应对室内空间进行声学处理。",
            "block_bbox": [
                147,
                294,
                1071,
                418
            ],
            "block_id": 2,
            "block_order": 3,
            "group_id": 2,
            "block_polygon_points": [
                [
                    147.0,
                    294.0
                ],
                [
                    1071.0,
                    294.0
                ],
                [
                    1071.0,
