        {
            "block_label": "paragraph_title",
            "block_content": "8.1.8 教学用房的门窗设置应符合下列规定：",
            "block_bbox": [
                147,
                323,
                753,
                359
            ],
            "block_id": 2,
            "block_order": 3,
            "group_id": 2,
            "block_polygon_points": [
