                ],
                [
                    149.0,
                    656.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "2 当采用换气次数确定室内通风量时，其换气次数不应低于本规范表9．1．3的规定；",
            "block_bbox": [
                149,
                665,
                1072,
                744
