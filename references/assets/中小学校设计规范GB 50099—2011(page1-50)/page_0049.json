        },
        {
            "block_label": "text",
            "block_content": "5 中小学校的楼梯栏杆不得采用易于攀登的构造和花饰；杆件或花饰的镂空处净距不得大于0.11m；",
            "block_bbox": [
                149,
                573,
                1073,
                653
            ],
            "block_id": 6,
            "block_order": 7,
            "group_id": 6,
            "block_polygon_points": [
