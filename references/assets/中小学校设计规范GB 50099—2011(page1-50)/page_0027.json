        {
            "block_label": "text",
            "block_content": "5．10．1体育建筑设施包括风雨操场、游泳池或游泳馆。体育建筑设施的位置应邻近室外体育场，并宜便于向社会开放。",
            "block_bbox": [
                147,
                405,
                1073,
                485
            ],
            "block_id": 3,
            "block_order": 4,
            "group_id": 3,
            "block_polygon_points": [
